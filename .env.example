DATABASE_URL=sqlite:///./exam_preparation.db

# Общие ключи внешних провайдеров. Настоящие значения должны храниться только в локальном .env.
OPENAI_API_KEY=your_openai_key_here
POLZA_API_KEY=your_polza_ai_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here
GEMINI_API_KEY=your_gemini_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
YANDEX_API_KEY=your_yandex_api_key_here
YANDEX_GPT_API_KEY=your_yandex_gpt_api_key_here
YANDEX_FOLDER_ID=your_yandex_folder_id_here
YANDEX_GPT_FOLDER_ID=your_yandex_folder_id_here

# Адреса внешних API.
OPENAI_BASE_URL=https://api.openai.com/v1
POLZA_BASE_URL=https://polza.ai/api/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
YANDEX_GPT_BASE_URL=https://ai.api.cloud.yandex.net/v1
YANDEX_OCR_BASE_URL=https://ai.api.cloud.yandex.net/ocr/v1/recognizeText
YANDEX_DATA_LOGGING_ENABLED=false

# TopicGuardAgent: контроль учебной тематики и академической честности.
TOPIC_GUARD_PROVIDER=openai
TOPIC_GUARD_API_KEY=your_polza_ai_key_here
TOPIC_GUARD_BASE_URL=https://polza.ai/api/v1
TOPIC_GUARD_MODEL=openai/gpt-4.1-nano

# TutorChatAgent: учебный диалог с учеником.
TUTOR_CHAT_PROVIDER=openai
TUTOR_CHAT_API_KEY=your_polza_ai_key_here
TUTOR_CHAT_BASE_URL=https://polza.ai/api/v1
TUTOR_CHAT_MODEL=openai/gpt-4.1-nano

# TextRecognitionAgent: распознавание текста из фото или PDF решения.
TEXT_RECOGNITION_PROVIDER=yandex_ocr
TEXT_RECOGNITION_MODEL=page

# SolutionReviewAgent: анализ решения и комментарий по качеству работы.
SOLUTION_REVIEW_PROVIDER=openai
SOLUTION_REVIEW_API_KEY=your_polza_ai_key_here
SOLUTION_REVIEW_BASE_URL=https://polza.ai/api/v1
SOLUTION_REVIEW_MODEL=openai/gpt-4.1-mini

# TaskGeneratorAgent: формирование похожих заданий для закрепления темы.
TASK_GENERATOR_PROVIDER=openai
TASK_GENERATOR_API_KEY=your_polza_ai_key_here
TASK_GENERATOR_BASE_URL=https://polza.ai/api/v1
TASK_GENERATOR_MODEL=openai/gpt-4.1-nano

# Локальный тестовый режим без обращения к внешним API.
AI_MOCK_MODE=false

# Совместимость со старой схемой конфигурации.
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
AI_PROVIDER=
AI_TIMEOUT_SECONDS=30

# Лимит истории чата до сохранения краткого содержания диалога.
CHAT_SUMMARY_CHAR_LIMIT=400000
